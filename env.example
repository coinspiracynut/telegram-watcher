# Telegram API Credentials
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Optional: Phone number for auto-login hint
TELEGRAM_PHONE=+1234567890

# Channels to monitor (comma-separated)
# Can be channel usernames, IDs, or invite links
WATCHED_CHANNELS=channel1,channel2,-1001234567890

# Telegram Bot for notifications (optional)
# Get bot token from @BotFather on Telegram
# Get chat ID by messaging your bot and visiting: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_NOTIFICATION_CHAT_ID=your_chat_id_here

# Solana Trading Configuration (optional)
# Wallet private key (base58 or base64 encoded)
SOLANA_WALLET_PRIVATE_KEY=your_wallet_private_key_here
# RPC endpoint (default: mainnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional API key for solana-swap (get from swap-api@solanatracker.io)
SOLANA_SWAP_API_KEY=your_api_key_here
# Optional: Custom send endpoint for swaps (solana-swap may require their endpoint)
# Check solana-swap docs or contact them for the correct endpoint
SOLANA_CUSTOM_SEND_ENDPOINT=

# Auto-buy amount in SOL when new token discovered
AUTO_BUY_AMOUNT_SOL=0.5
# Profit target: sell when value >= (PROFIT_TARGET_PERCENT / 100) * buy_amount
# e.g. 250 = sell when value is 2.5x the buy amount (150% profit)
PROFIT_TARGET_PERCENT=250.0
# Percentage of position to sell when target hit
SELL_PERCENTAGE=50.0

# OpenRouter AI Configuration (optional — enables AI token tagging)
# Get API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model to use (default: anthropic/claude-sonnet-4)
# Other options: openai/gpt-4o-mini, google/gemini-2.0-flash, etc.
OPENROUTER_MODEL=anthropic/claude-sonnet-4
